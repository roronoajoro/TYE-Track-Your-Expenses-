# ─────────────────────────────────────────────────────────────────────────────
# Taka Gelo Koi — Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# ⚠️  NEVER commit the real .env.local file to version control.
#     Vite exposes only variables prefixed with VITE_ to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL
VITE_API_URL=http://localhost:8000

# Google OAuth 2.0 Client ID (same value as backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
