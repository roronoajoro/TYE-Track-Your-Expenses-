# ─────────────────────────────────────────────────────────────────────────────
# Taka Gelo Koi — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
google_credentials/

# ── Python ────────────────────────────────────────────────────────────────────
venv/
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── Database files (local dev only) ──────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/coverage/

# ── Uploaded files (runtime artifacts) ────────────────────────────────────────
backend/app/uploads/

# ── OS & Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
