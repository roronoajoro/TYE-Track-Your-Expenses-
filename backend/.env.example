# =============================================================
# TYE Backend — Environment Variables
# =============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values in .env
# 3. NEVER commit .env to Git
# =============================================================

# --- PostgreSQL Database ---
# Format: postgresql://USER:PASSWORD@HOST/DATABASE
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@localhost/tye_db

# --- Google OAuth (Client ID from Google Cloud Console) ---
# Get it from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# --- Google Cloud Vision API (for OCR receipt scanning) ---
# Get it from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable "Cloud Vision API" first
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here
